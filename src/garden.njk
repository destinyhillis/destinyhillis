---
title: "Garden"
layout: base.njk
visibility: public
permalink: /garden/
---

<section class="now-page">
  <h1>Garden</h1>
  <p class="now-subtitle">notes, fragments, and things growing in the margins</p>

  {% for note in collections.notes %}
  <article class="garden-card">
    <a href="{{ note.url }}">
      <h2>{{ note.data.title }}</h2>
      <time datetime="{{ note.date | isoDate }}">{{ note.date | readableDate }}</time>
      {% if note.data.summary %}
      <p>{{ note.data.summary }}</p>
      {% endif %}
      {% if note.data.tags %}
      <ul class="tag-list">
        {% for tag in note.data.tags %}
        <li class="tag">{{ tag }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </a>
  </article>
  {% endfor %}

  {% if collections.notes.length == 0 %}
  <p class="empty-state">Nothing planted yet. Check back soon.</p>
  {% endif %}
</section>
